    "minimum_width_on_colour_mm": 46,
    "minimum_width_on_white_px": 16,
    "minimum_width_on_white_mm": 6,
    "clear_space": "half the symbol width",
    "usage_note": "Works strongest on black or charcoal apparel."
  },
  "slogan_mark": {
    "name": "Shortest Distance Mark",
